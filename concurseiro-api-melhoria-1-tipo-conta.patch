diff --git a/src/main/resources/db/changelog/changes/020-add-tipo-conta-usuarios.yaml b/src/main/resources/db/changelog/changes/020-add-tipo-conta-usuarios.yaml
new file mode 100644
index 0000000..0000000
--- /dev/null
+++ b/src/main/resources/db/changelog/changes/020-add-tipo-conta-usuarios.yaml
@@ -0,0 +1,33 @@
+databaseChangeLog:
+  - changeSet:
+      id: 020-add-tipo-conta-usuarios
+      author: mauricio
+
+      changes:
+        - addColumn:
+            tableName: usuarios
+            columns:
+              - column:
+                  name: tipo_conta
+                  type: varchar(20)
+                  defaultValue: PAINEL
+                  constraints:
+                    nullable: false
+
+        - sql:
+            splitStatements: false
+            sql: |
+              UPDATE public.usuarios
+              SET tipo_conta = CASE
+                  WHEN role = 'USUARIO_FINAL' THEN 'APP'
+                  ELSE 'PAINEL'
+              END;
+
+        - addCheckConstraint:
+            tableName: usuarios
+            constraintName: usuarios_tipo_conta_check
+            checkConstraint: "tipo_conta IN ('PAINEL', 'APP')"
+
+      rollback:
+        - dropColumn:
+            tableName: usuarios
+            columnName: tipo_conta
